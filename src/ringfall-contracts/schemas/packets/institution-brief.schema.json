{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/packets/institution-brief.schema.json",
  "title": "InstitutionBrief",
  "type": "object",
  "additionalProperties": false,
  "if": {
    "properties": {
      "withheld_items_count": { "minimum": 1 }
    },
    "required": ["withheld_items_count"]
  },
  "then": {
    "required": ["withholding_record_refs"]
  },
  "required": [
    "packet_id",
    "packet_type",
    "schema_version",
    "issuer_id",
    "issuer_layer",
    "issued_at_tick",
    "source_context_id",
    "institution_id",
    "cycle_id",
    "summary",
    "evidence",
    "uncertainties",
    "risk_flags",
    "withheld_items_count",
    "recommended_orders",
    "escalation_needed",
    "confidence"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_type": { "const": "InstitutionBrief" },
    "schema_version": { "const": "0.1" },
    "issuer_id": { "type": "string", "minLength": 1 },
    "issuer_layer": {
      "description": "Origin layer label only; this does not grant runtime authority.",
      "enum": ["L1", "L2", "L3", "sim", "system"]
    },
    "issued_at_tick": { "type": "integer", "minimum": 0 },
    "issued_at_turn": { "type": "string", "minLength": 1 },
    "source_context_id": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "visibility_intent": { "enum": ["private", "internal", "institutional", "public"] },
    "urgency": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "institution_id": { "type": "string", "minLength": 1 },
    "cycle_id": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "uncertainties": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "risk_flags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "withheld_items_count": { "type": "integer", "minimum": 0 },
    "withholding_record_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "recommended_orders": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "priority": { "enum": ["low", "normal", "medium", "high", "critical"] },
          "rationale": { "type": "string" }
        }
      }
    },
    "escalation_needed": { "type": "boolean" },
    "narrative_line": { "type": "string" }
  }
}
