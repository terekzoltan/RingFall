{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/packets/scene-action-packet.schema.json",
  "title": "SceneActionPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_type",
    "schema_version",
    "issuer_id",
    "issuer_layer",
    "issued_at_tick",
    "source_context_id",
    "scene_id",
    "actor_id",
    "scene_goal",
    "actions"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_type": { "const": "SceneActionPacket" },
    "schema_version": { "const": "0.1" },
    "issuer_id": { "type": "string", "minLength": 1 },
    "issuer_layer": {
      "description": "Origin layer label only; this does not grant runtime authority.",
      "enum": ["L1", "L2", "L3", "sim", "system"]
    },
    "issued_at_tick": { "type": "integer", "minimum": 0 },
    "issued_at_turn": { "type": "string", "minLength": 1 },
    "source_context_id": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "visibility_intent": { "enum": ["private", "internal", "institutional", "public"] },
    "urgency": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "scene_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "scene_goal": { "type": "string", "minLength": 1 },
    "chosen_strategy": { "type": "string" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "use_tool" } }, "required": ["type"] },
            "then": { "required": ["tool_id", "action"] }
          },
          {
            "if": { "properties": { "type": { "const": "issue_work_order" } }, "required": ["type"] },
            "then": { "required": ["target_crew_id", "action"] }
          },
          {
            "if": { "properties": { "type": { "const": "communicate" } }, "required": ["type"] },
            "then": { "required": ["channel", "message_intent"] }
          }
        ],
        "properties": {
          "type": { "enum": ["use_tool", "issue_work_order", "communicate"] },
          "tool_id": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "minLength": 1 },
          "target_crew_id": { "type": "string", "minLength": 1 },
          "channel": { "type": "string", "minLength": 1 },
          "message_intent": { "type": "string", "minLength": 1 }
        }
      }
    },
    "communication": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["channel", "message_intent"],
        "properties": {
          "channel": { "type": "string", "minLength": 1 },
          "message_intent": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risks_acknowledged": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
