{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/packets/work-order-request.schema.json",
  "title": "WorkOrderRequest",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    { "required": ["target_crew_id"] },
    { "required": ["target_crew_pool_id"] }
  ],
  "required": [
    "packet_id",
    "packet_type",
    "schema_version",
    "issuer_id",
    "issuer_layer",
    "issued_at_tick",
    "source_context_id",
    "target_location",
    "task_type",
    "priority"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_type": { "const": "WorkOrderRequest" },
    "schema_version": { "const": "0.1" },
    "issuer_id": { "type": "string", "minLength": 1 },
    "issuer_layer": {
      "description": "Origin layer label only; this does not grant runtime authority.",
      "enum": ["L1", "L2", "L3", "sim", "system"]
    },
    "issued_at_tick": { "type": "integer", "minimum": 0 },
    "issued_at_turn": { "type": "string", "minLength": 1 },
    "source_context_id": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "visibility_intent": { "enum": ["private", "internal", "institutional", "public"] },
    "urgency": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "target_crew_id": { "type": "string", "minLength": 1 },
    "target_crew_pool_id": { "type": "string", "minLength": 1 },
    "target_location": { "type": "string", "minLength": 1 },
    "task_type": { "type": "string", "minLength": 1 },
    "priority": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "risk_tolerance": { "enum": ["low", "moderate", "high"] },
    "authorized_resources": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "expected_report": { "type": "string" },
    "fallback_protocol": { "type": "string" },
    "stealth_level": { "enum": ["normal", "quiet", "covert"] },
    "public_visibility": { "enum": ["private", "internal", "institutional", "public"] }
  }
}
