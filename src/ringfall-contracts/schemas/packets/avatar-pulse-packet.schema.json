{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/packets/avatar-pulse-packet.schema.json",
  "title": "AvatarPulsePacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_type",
    "schema_version",
    "issuer_id",
    "issuer_layer",
    "issued_at_tick",
    "source_context_id",
    "actor_id"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_type": { "const": "AvatarPulsePacket" },
    "schema_version": { "const": "0.1" },
    "issuer_id": { "type": "string", "minLength": 1 },
    "issuer_layer": {
      "description": "Origin layer label only; this does not grant runtime authority.",
      "enum": ["L1", "L2", "L3", "sim", "system"]
    },
    "issued_at_tick": { "type": "integer", "minimum": 0 },
    "issued_at_turn": { "type": "string", "minLength": 1 },
    "source_context_id": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "visibility_intent": { "enum": ["private", "internal", "institutional", "public"] },
    "urgency": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "actor_id": { "type": "string", "minLength": 1 },
    "local_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stress": { "type": "number", "minimum": 0, "maximum": 1 },
        "fatigue": { "type": "number", "minimum": 0, "maximum": 1 },
        "immediate_risk": { "enum": ["low", "medium", "high", "critical"] }
      }
    },
    "observed": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "belief_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "confidence"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "intent": { "type": "string" },
    "requested_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packet_type", "draft_ref"],
        "properties": {
          "packet_type": { "enum": ["WorkOrderRequest", "ToolActionRequest", "SceneActionPacket"] },
          "draft_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "social_note": { "type": "string" },
    "risk_flags": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
