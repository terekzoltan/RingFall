{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/packets/institution-order.schema.json",
  "title": "InstitutionOrder",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_type",
    "schema_version",
    "issuer_id",
    "issuer_layer",
    "issued_at_tick",
    "source_context_id",
    "institution_id",
    "issuer_seat_id",
    "order_type",
    "target_scope",
    "visibility",
    "expected_effect"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_type": { "const": "InstitutionOrder" },
    "schema_version": { "const": "0.1" },
    "issuer_id": { "type": "string", "minLength": 1 },
    "issuer_layer": {
      "description": "Origin layer label only; this does not grant runtime authority.",
      "enum": ["L1", "L2", "L3", "sim", "system"]
    },
    "issued_at_tick": { "type": "integer", "minimum": 0 },
    "issued_at_turn": { "type": "string", "minLength": 1 },
    "source_context_id": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "visibility_intent": { "enum": ["private", "internal", "institutional", "public"] },
    "urgency": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "institution_id": { "type": "string", "minLength": 1 },
    "issuer_seat_id": { "type": "string", "minLength": 1 },
    "order_type": { "type": "string", "minLength": 1 },
    "target_scope": { "type": "string", "minLength": 1 },
    "priority": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "resources": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "constraints": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "duration": { "type": "string", "minLength": 1 },
    "sunset_condition": { "type": "string", "minLength": 1 },
    "visibility": { "enum": ["private", "internal", "institutional", "public"] },
    "expected_effect": { "type": "string", "minLength": 1 },
    "known_tradeoffs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "audit_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
