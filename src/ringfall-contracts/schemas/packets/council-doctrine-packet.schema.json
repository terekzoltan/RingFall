{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/packets/council-doctrine-packet.schema.json",
  "title": "CouncilDoctrinePacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_type",
    "schema_version",
    "issuer_id",
    "issuer_layer",
    "issued_at_tick",
    "source_context_id",
    "council_cycle_id",
    "decision_mode",
    "doctrine_shift",
    "macro_orders",
    "charter_conditions",
    "audit_visibility"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_type": { "const": "CouncilDoctrinePacket" },
    "schema_version": { "const": "0.1" },
    "issuer_id": { "type": "string", "minLength": 1 },
    "issuer_layer": {
      "description": "Origin layer label only; this does not grant runtime authority.",
      "enum": ["L1", "L2", "L3", "sim", "system"]
    },
    "issued_at_tick": { "type": "integer", "minimum": 0 },
    "issued_at_turn": { "type": "string", "minLength": 1 },
    "source_context_id": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "visibility_intent": { "enum": ["private", "internal", "institutional", "public"] },
    "urgency": { "enum": ["low", "normal", "medium", "high", "critical"] },
    "council_cycle_id": { "type": "string", "minLength": 1 },
    "decision_mode": { "type": "string", "minLength": 1 },
    "doctrine_shift": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["survival_priority"] },
        { "required": ["infrastructure_priority"] },
        { "required": ["science_priority"] },
        { "required": ["truthfulness_policy"] },
        { "required": ["security_posture"] }
      ],
      "properties": {
        "survival_priority": { "type": "number", "minimum": 0, "maximum": 1 },
        "infrastructure_priority": { "type": "number", "minimum": 0, "maximum": 1 },
        "science_priority": { "type": "number", "minimum": 0, "maximum": 1 },
        "truthfulness_policy": { "enum": ["full_disclosure", "partial_disclosure", "controlled_disclosure", "emergency_secrecy"] },
        "security_posture": { "enum": ["normal", "targeted_hardening", "broad_lockdown", "emergency_control"] }
      }
    },
    "macro_orders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "duration"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "duration": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string" }
        }
      }
    },
    "emergency_measures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["measure_type", "granted_to", "scope", "duration", "sunset_condition", "public_justification_required"],
        "properties": {
          "measure_type": { "type": "string", "minLength": 1 },
          "granted_to": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "minLength": 1 },
          "duration": { "type": "string", "minLength": 1 },
          "sunset_condition": { "type": "string", "minLength": 1 },
          "public_justification_required": { "type": "boolean" }
        }
      }
    },
    "charter_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "dissenting_positions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seat", "objection"],
        "properties": {
          "seat": { "type": "string", "minLength": 1 },
          "objection": { "type": "string", "minLength": 1 }
        }
      }
    },
    "dissent_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "audit_visibility": { "enum": ["internal", "council_only", "council_and_dev_replay", "public_summary"] }
  }
}
