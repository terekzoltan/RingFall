{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/traces/cost-event.schema.json",
  "title": "CostEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "schema_version",
    "cost_event_id",
    "cognition_id",
    "run_id",
    "turn_ref",
    "tick",
    "lane",
    "run_mode",
    "provider",
    "model_id",
    "input_tokens",
    "output_tokens",
    "estimated_cost_usd",
    "cost_estimate_status",
    "latency_ms",
    "retry_count",
    "fallback_count",
    "schema_valid"
  ],
  "properties": {
    "event_type": { "const": "CostEvent" },
    "schema_version": { "const": "0.1" },
    "cost_event_id": { "type": "string", "minLength": 1 },
    "cognition_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "turn_ref": { "type": "string", "minLength": 1 },
    "tick": { "type": "integer", "minimum": 0 },
    "lane": { "type": "string", "minLength": 1 },
    "run_mode": { "enum": ["dev", "replay", "canonical_candidate", "canonical"] },
    "provider": { "type": "string", "minLength": 1 },
    "model_id": { "type": "string", "minLength": 1 },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "estimated_cost_usd": { "type": "number", "minimum": 0 },
    "cost_estimate_status": { "enum": ["known", "estimated", "free_or_mock_zero", "unavailable"] },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "retry_count": { "type": "integer", "minimum": 0 },
    "fallback_count": { "type": "integer", "minimum": 0 },
    "schema_valid": {
      "description": "Evidence copied from validation results; this field does not imply runtime validation tooling exists in W1-S5.",
      "type": "boolean"
    },
    "target_id": { "type": "string", "minLength": 1 },
    "request_ref": { "$ref": "#/$defs/source_ref" },
    "cognition_trace_ref": { "$ref": "#/$defs/source_ref" },
    "context_ref": { "$ref": "#/$defs/source_ref" },
    "schema_ref": { "$ref": "#/$defs/source_ref" },
    "temperature": { "type": "number", "minimum": 0 },
    "max_output_tokens": { "type": "integer", "minimum": 1 },
    "free_model_used": { "type": "boolean" },
    "fallback_used": { "type": "boolean" },
    "fallback_reason": { "type": "string", "minLength": 1 },
    "rate_limited": { "type": "boolean" },
    "provider_error": { "type": "boolean" },
    "cost_cap_usd": { "type": "number", "minimum": 0 },
    "budget_status": { "enum": ["within_budget", "warn", "exceeded", "not_applicable"] }
  },
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "ref_type"],
      "properties": {
        "ref_id": { "type": "string", "minLength": 1 },
        "ref_type": { "type": "string", "minLength": 1 },
        "artifact_uri": { "type": "string", "minLength": 1 }
      }
    }
  }
}
