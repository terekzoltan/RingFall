{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/traces/run-manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "schema_version",
    "created_at_utc",
    "scenario_id",
    "run_mode",
    "simulation_seed",
    "contract_version",
    "tracks",
    "status"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "0.1" },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "run_mode": { "enum": ["dev", "replay", "canonical_candidate", "canonical"] },
    "simulation_seed": { "type": "integer" },
    "contract_version": { "type": "string", "minLength": 1 },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["track_id", "role", "artifact_refs"],
        "properties": {
          "track_id": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "artifact_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/source_ref" }
          }
        }
      }
    },
    "status": { "enum": ["planned", "running", "completed", "failed", "aborted"] },
    "canonical_per_actor_calls": { "type": "boolean" },
    "batched_calls_enabled": { "type": "boolean" },
    "free_models_enabled": { "type": "boolean" },
    "quality_escalation_enabled": { "type": "boolean" },
    "replayability_level": { "enum": ["none", "artifact_replay_supported", "deterministic_replay_supported"] }
  },
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "ref_type"],
      "properties": {
        "ref_id": { "type": "string", "minLength": 1 },
        "ref_type": { "type": "string", "minLength": 1 },
        "artifact_uri": { "type": "string", "minLength": 1 }
      }
    }
  }
}
