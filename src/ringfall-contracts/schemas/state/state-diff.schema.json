{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ringfall://schemas/state/state-diff.schema.json",
  "title": "StateDiff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diff_type",
    "schema_version",
    "diff_id",
    "tick",
    "source_action_trace_id",
    "changes",
    "deterministic_seed"
  ],
  "properties": {
    "diff_type": { "const": "StateDiff" },
    "schema_version": { "const": "0.1" },
    "diff_id": { "type": "string", "minLength": 1 },
    "tick": { "type": "integer", "minimum": 0 },
    "source_action_trace_id": { "type": "string", "minLength": 1 },
    "system_refs": { "type": "array", "items": { "$ref": "#/$defs/source_ref" } },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "old", "new", "visibility"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "old": { "$ref": "#/$defs/json_value" },
          "new": { "$ref": "#/$defs/json_value" },
          "visibility": { "enum": ["hidden", "issuer_observable", "institution_observable", "public_observable", "dev_only"] }
        }
      }
    },
    "deterministic_seed": { "type": "integer" }
  },
  "$defs": {
    "json_value": {
      "type": ["array", "boolean", "integer", "null", "number", "object", "string"]
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "ref_type"],
      "properties": {
        "ref_id": { "type": "string", "minLength": 1 },
        "ref_type": { "type": "string", "minLength": 1 },
        "artifact_uri": { "type": "string", "minLength": 1 }
      }
    }
  }
}
